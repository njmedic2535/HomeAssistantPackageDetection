blueprint:
  name: AI Package Detector (Official Media Path)
  description: >
    📦 AI Package Detector. Saves snapshots to /media/packages/ 
    and uses the official media-source URI for AI Task resolution.
  domain: automation
  input:
    camera_entities:
      name: Cameras
      selector:
        entity:
          multiple: true
          domain: camera
    ai_agent:
      name: AI Task Agent
      selector:
        entity:
          domain: ai_task
    motion_sensor_entities:
      name: Optional Motion Sensors
      default: []
      selector:
        entity:
          multiple: true
          domain: binary_sensor
    image_prompt_user_details:
      name: Image Analysis Details
      default: "Focus on the area around the door and doormat."
      selector:
        text:
          multiline: true
    time_pattern_minutes:
      name: Check Interval (Minutes)
      default: "/15"
      selector:
        text:
    notification_target:
      name: Notification Target
      default: []
      selector:
        device:
          integration: mobile_app
          multiple: true
    previous_package_count_helper:
      name: Package Count Helper
      selector:
        entity:
          domain: input_number
    package_status_helper:
      name: Package Status Helper
      selector:
        entity:
          domain: input_boolean

variables:
  camera_entities: !input camera_entities
  previous_package_count_helper: !input previous_package_count_helper
  package_status_helper: !input package_status_helper

trigger:
  - platform: time_pattern
    minutes: !input time_pattern_minutes
    id: time_trigger
  - platform: state
    entity_id: !input motion_sensor_entities
    to: "on"
    id: motion_trigger

action:
  - if:
      - condition: trigger
        id: motion_trigger
    then:
      - delay: "00:00:05"

  # 1. Take Snapshots to /media/packages/
  - parallel:
      - repeat:
          for_each: "{{ camera_entities }}"
          sequence:
            - action: camera.snapshot
              data:
                filename: >
                  {%- set camera_name = repeat.item | replace('camera.', '') | replace('.', '_') -%}
                  /media/packages/{{ camera_name }}.jpg
              target:
                entity_id: "{{ repeat.item }}"

  - delay: "00:00:02"

  # 2. Call AI Task using the media_source/packages path
  - action: ai_task.generate_data
    data:
      entity_id: !input ai_agent
      task_name: "package_check"
      instructions: >
        Count delivery packages in the images.
        Previous count: {{ states(previous_package_count_helper)|int(0) }}
        Context: {{ image_prompt_user_details }}
      attachments: >
        {% set ns = namespace(items=[]) %}
        {% for camera in camera_entities %}
          {% set camera_name = camera | replace('camera.', '') | replace('.', '_') %}
          {% set ns.items = ns.items + [{'media_content_id': 'media-source://media_source/packages/' ~ camera_name ~ '.jpg', 'media_content_type': 'image/jpeg'}] %}
        {% endfor %}
        {{ ns.items }}
      structure:
        count: "integer"
        message: "string"
        best_image_name: "string"
    response_variable: ai_response

  - variables:
      count: "{{ ai_response.data.count | int(default=-1) }}"
      desc: "{{ ai_response.data.message }}"
      best_img: "{{ ai_response.data.best_image_name }}"

  # 3. Handle Results
  - choose:
      - conditions:
          - condition: template
            value_template: "{{ count > (states(previous_package_count_helper) | int(0)) }}"
        sequence:
          - repeat:
              for_each: !input notification_target
              sequence:
                - action: "notify.mobile_app_{{ device_attr(repeat.item, 'name') | slugify }}"
                  data:
                    title: "📦 New Package"
                    message: "{{ desc }}"
                    data:
                      # Note: Mobile apps cannot see /media/ directly. 
                      # For notifications, it is better to use /local/ (www) if you want images.
                      # If you want images in notifications, we'll need to copy the file to /config/www/
                      attachment:
                        url: "/media/local/packages/{{ best_img }}"
                        content-type: jpeg
      
      - conditions:
          - condition: template
            value_template: "{{ count < (states(previous_package_count_helper) | int(0)) and count >= 0 }}"
        sequence:
          - repeat:
              for_each: !input notification_target
              sequence:
                - action: "notify.mobile_app_{{ device_attr(repeat.item, 'name') | slugify }}"
                  data:
                    title: "📦 Package Removed"
                    message: "The porch is now clear."

  # 4. Final Updates
  - if:
      - condition: template
        value_template: "{{ count != -1 }}"
    then:
      - action: input_number.set_value
        target:
          entity_id: "{{ previous_package_count_helper }}"
        data:
          value: "{{ count }}"
      - action: "input_boolean.turn_{{ 'on' if count > 0 else 'off' }}"
        target:
          entity_id: "{{ package_status_helper }}"

mode: single
