blueprint:
  name: AI Package Detector (Direct Camera Feed)
  description: >
    📦 AI Package Detector. Bypasses file path issues by sending 
    the camera entities directly to the AI Task.
  domain: automation
  input:
    camera_entities:
      name: Cameras
      selector:
        entity:
          multiple: true
          domain: camera
    ai_agent:
      name: AI Task Agent
      selector:
        entity:
          domain: ai_task
    motion_sensor_entities:
      name: Optional Motion Sensors
      default: []
      selector:
        entity:
          multiple: true
          domain: binary_sensor
    image_prompt_user_details:
      name: Image Analysis Details
      default: "Focus on the area around the door and doormat."
      selector:
        text:
          multiline: true
    time_pattern_minutes:
      name: Check Interval (Minutes)
      default: "/15"
      selector:
        text:
    notification_target:
      name: Notification Target
      default: []
      selector:
        device:
          integration: mobile_app
          multiple: true
    previous_package_count_helper:
      name: Package Count Helper
      selector:
        entity:
          domain: input_number
    package_status_helper:
      name: Package Status Helper
      selector:
        entity:
          domain: input_boolean

variables:
  camera_entities: !input camera_entities
  previous_package_count_helper: !input previous_package_count_helper
  package_status_helper: !input package_status_helper

trigger:
  - platform: time_pattern
    minutes: !input time_pattern_minutes
    id: time_trigger
  - platform: state
    entity_id: !input motion_sensor_entities
    to: "on"
    id: motion_trigger

action:
  - if:
      - condition: trigger
        id: motion_trigger
    then:
      - delay: "00:00:02"

  # 1. Direct AI Task Call using camera entities
  - action: ai_task.generate_data
    data:
      entity_id: !input ai_agent
      task_name: "package_check"
      instructions: >
        Look at the live camera feeds provided. Count any delivery packages present.
        Previous count: {{ states(previous_package_count_helper)|int(0) }}
        User Notes: {{ image_prompt_user_details }}
      # We pass the entities directly. The AI Task integration will take the snapshots for us.
      attachments: >
        {% set ns = namespace(items=[]) %}
        {% for camera in camera_entities %}
          {% set ns.items = ns.items + [{'media_content_id': camera, 'media_content_type': 'image/jpeg'}] %}
        {% endfor %}
        {{ ns.items }}
      structure:
        count:
          selector:
            number:
              min: 0
              max: 10
        message:
          selector:
            text:
    response_variable: ai_response

  - variables:
      count: "{{ ai_response.data.count | int(default=-1) }}"
      desc: "{{ ai_response.data.message }}"

  # 2. Handle Logic & Notifications
  - choose:
      # NEW PACKAGE
      - conditions:
          - condition: template
            value_template: "{{ count > (states(previous_package_count_helper) | int(0)) }}"
        sequence:
          - repeat:
              for_each: !input notification_target
              sequence:
                - action: "notify.mobile_app_{{ device_attr(repeat.item, 'name') | slugify }}"
                  data:
                    title: "📦 New Package"
                    message: "{{ desc }}"
      
      # PACKAGE REMOVED
      - conditions:
          - condition: template
            value_template: "{{ count < (states(previous_package_count_helper) | int(0)) and count >= 0 }}"
        sequence:
          - repeat:
              for_each: !input notification_target
              sequence:
                - action: "notify.mobile_app_{{ device_attr(repeat.item, 'name') | slugify }}"
                  data:
                    title: "📦 Package Picked Up"
                    message: "The porch is now clear."

  # 3. Final Updates
  - if:
      - condition: template
        value_template: "{{ count != -1 }}"
    then:
      - action: input_number.set_value
        target:
          entity_id: "{{ previous_package_count_helper }}"
        data:
          value: "{{ count }}"
      - action: "input_boolean.turn_{{ 'on' if count > 0 else 'off' }}"
        target:
          entity_id: "{{ package_status_helper }}"

mode: single
